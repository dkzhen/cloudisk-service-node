# Server Configuration
PORT=3001
NODE_ENV=development

# CORS Configuration
# Set to your frontend domain in production
# Example: CORS_ORIGIN=https://yourdomain.com
CORS_ORIGIN=*

# Storage Configuration (optional, defaults are set in config)
# MAX_STORAGE_SIZE=5368709120  # 5GB in bytes
# MAX_FILE_SIZE=52428800       # 50MB in bytes

# Rate Limiting (optional, defaults are set in config)
# RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
# RATE_LIMIT_MAX=100           # max requests per window

# Image Optimization (optional, defaults are set in config)
# IMAGE_MAX_WIDTH=2000
# IMAGE_MAX_HEIGHT=2000
# IMAGE_QUALITY=80
